##############################
# Glitch vulnbox — live capture defaults
# cp .env.glitch.example .env && edit TEAM_ID + TICK_START
##############################

TIMESCALE="postgres://tulip@timescale:5432/tulip"

# Live capture (default) — assembler connects to pcap-bridge on the host
PCAP_OVER_IP="host.docker.internal:1337"
PCAP_BRIDGE_LISTEN="0.0.0.0:1337"
PCAP_BRIDGE_INTERFACE="any"
# Optional BPF, e.g. only vulnbox traffic: "host 10.100.42.1"
PCAP_BRIDGE_BPF=

# File mode fallback — leave PCAP_OVER_IP empty and set TRAFFIC_DIR_HOST instead
TRAFFIC_DIR_HOST="./services/test_pcap"
TRAFFIC_DIR_DOCKER="/traffic"

TEAM_ID=42
VM_IP="10.100.42.1"
GAME_ROUTER_IP="10.100.0.1"

TICK_START="2026-06-05T10:00:00Z"
TICK_LENGTH=120000
FLAG_LIFETIME=5
FLAG_REGEX="[A-Z0-9]{31}="

GLITCH_API_BASE="https://glitch.ad"
FLAGID_ENDPOINT="https://glitch.ad/api/flagids"
FLAGID_SCRAPE=1
FLAGID_SCAN=1
FLAGID_MODE=glitch
VISUALIZER_URL="https://glitch.ad"

# Services — optional; add via Tulip UI "Services" button instead
TULIP_SERVICES=

CONVERTER_DEFAULT=b64decode

# Protect Tulip UI + API (recommended on vulnbox)
TULIP_AUTH_PASSWORD=change-me

TOOLING_API_KEY=change-me-too
EXPLOITS_DIR_HOST="/root/exploits"
GLITCH_NOP_HOST="10.100.1.1"
