##############################
# AD Tooling — Glitch vulnbox example
# cp .env.example .env   then edit TEAM_ID + TICK_START + passwords
##############################

TIMESCALE="postgres://tulip@timescale:5432/tulip"

##############################
# Traffic capture
##############################

# Live capture (default for Glitch) — pcap-bridge streams tcpdump to Tulip
PCAP_OVER_IP="host.docker.internal:1337"
PCAP_BRIDGE_LISTEN="0.0.0.0:1337"
PCAP_BRIDGE_INTERFACE="any"
# Optional: limit to your vulnbox, e.g. PCAP_BRIDGE_BPF="host 10.100.42.1"
PCAP_BRIDGE_BPF=

# File mode fallback — clear PCAP_OVER_IP and use these instead
TRAFFIC_DIR_HOST="./services/test_pcap"
TRAFFIC_DIR_DOCKER="/traffic"

##############################
# Glitch game
##############################

TEAM_ID=1
VM_IP="10.100.1.1"
GAME_ROUTER_IP="10.100.0.1"

TICK_START="2026-06-05T10:00:00Z"
TICK_LENGTH=120000
FLAG_LIFETIME=5
FLAG_REGEX="[A-Z0-9]{31}="

# --- Glitch game infra (scoreboard) — NOT our Tulip stack ---
GLITCH_API_BASE="https://glitch.ad"
FLAGID_ENDPOINT="https://glitch.ad/api/flagids"
FLAGID_SCRAPE=1
FLAGID_SCAN=1
FLAGID_MODE=glitch
GLITCH_NOP_HOST="10.100.1.1"

# Optional external visualizer for graph "under attack" overlay (leave empty for Glitch)
VISUALIZER_URL=

# Services — optional; add via Tulip UI "Services" button instead
TULIP_SERVICES=

CONVERTER_DEFAULT=b64decode

##############################
# Auth (set these before deploying)
##############################

TULIP_AUTH_PASSWORD=change-me
TOOLING_API_KEY=change-me-too

##############################
# Exploit gateway
##############################

EXPLOITS_DIR_HOST="/root/exploits"
DEFAULT_TEAM=exploits
